    {
      "parameters": {
        "jsCode": "const incoming = $input.first();\nconst context = incoming.json || {};\nconst binary = incoming.binary || {};\nconst output = [];\n\nfunction simpleHash(value) {\n  let hash = 2166136261;\n  const text = String(value || '');\n  for (let index = 0; index < text.length; index++) {\n    hash ^= text.charCodeAt(index);\n    hash = Math.imul(hash, 16777619);\n  }\n  return `fnv1a-${(hash >>> 0).toString(16).padStart(8, '0')}`;\n}\n\nfunction decodeBase64(value) {\n  if (!value) return '';\n  if (typeof Buffer !== 'undefined') {\n    return Buffer.from(value, 'base64').toString('utf8');\n  }\n  if (typeof atob !== 'undefined') {\n    return decodeURIComponent(escape(atob(value)));\n  }\n  return String(value);\n}\n\nfunction pushSource(filePath, languageHint, sourceType, sourceCode) {\n  const source = String(sourceCode || '');\n  if (!source.trim()) return;\n  const lines = source.split('\\n');\n  output.push({\n    json: {\n      scan_id: context.scan_id,\n      submitted_at: context.submitted_at,\n      file_path: filePath || 'inline-source-code.txt',\n      language_hint: languageHint || (filePath || '').split('.').pop(),\n      source_type: sourceType,\n      ingestion_method: context.ingestion_method,\n      source_code: source,\n      file_hash: simpleHash(source),\n      line_count: lines.length,\n      numbered_source: lines.map((line, index) => `${index + 1}: ${line}`).join('\\n')\n    }\n  });\n}\n\nfor (const [key, file] of Object.entries(binary)) {\n  pushSource(file.fileName || key, (file.fileName || key).split('.').pop(), 'uploaded_file', decodeBase64(file.data));\n}\n\nfor (const file of context.json_files || []) {\n  pushSource(file.path || file.name || 'inline-source-code.txt', file.language || (file.path || '').split('.').pop(), 'json_files_payload', file.content || file.source_code || file.source || '');\n}\n\npushSource(context.file_path, context.language_hint, 'single_json_payload', context.source_code);\n\nreturn output;"
      },
