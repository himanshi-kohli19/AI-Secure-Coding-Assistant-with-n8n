      "name": "Sticky Note1"
    },
    {
      "parameters": {
        "content": "# Source Preparation\nThe workflow checks whether valid source code exists. It then adds line numbers and a file hash so the AI can identify vulnerable LOC accurately and maintain traceability.",
        "height": 464,
        "width": 448,
